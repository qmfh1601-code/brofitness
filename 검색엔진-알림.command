#!/bin/bash
# ─────────────────────────────────────────────
#  IndexNow — 네이버·빙에 "새 글 올라왔다" 즉시 알림
#  ※ 반드시 'Netlify 배포가 끝난 뒤' 실행하세요. (URL이 인터넷에 살아있어야 함)
# ─────────────────────────────────────────────
cd "$(dirname "$0")"
echo "■ 검색엔진(네이버·빙)에 새 글 알림 전송…"
python3 tools/publish.py --ping
echo ""
echo "(구글은 IndexNow 미지원 → 사이트맵/서치콘솔로 자동 수집됩니다)"
echo "끝났습니다. 이 창은 닫으셔도 됩니다."
read -n1
